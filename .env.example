# ---------------------------------------------------------------------------
# Copy this file to `.env` and replace placeholder values before deploying.
# ---------------------------------------------------------------------------

# PostgreSQL
POSTGRES_PASSWORD=replace-with-strong-password

# JWT signing secret — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-64-char-random-secret

# Backend runtime
ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=http://localhost:3000,http://localhost

# Frontend -> backend base URL (reached by the browser).
# In the Docker/Nginx setup this is the public origin + /api, e.g.
#   http://localhost/api
NEXT_PUBLIC_API_URL=http://localhost:8000

# Bootstrap admin account (created on first boot by scripts/seed_admin.py).
# CHANGE the password from the default in any real deployment.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin123
ADMIN_FULL_NAME=System Administrator
ADMIN_DEPARTMENT=مدیریت
