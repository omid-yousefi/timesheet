# Dependencies
**/node_modules/

# Next.js build output
**/.next/

# Python virtual environments
**/.venv/

# Python bytecode caches
**/__pycache__/
**/*.pyc

# Keep our source `lib/` folders tracked (Next.js lib + Python packages).
# Only ignore generated caches / build artifacts.
!**/lib/

# Environment files hold secrets and must never be committed.
**/.env
**/.env.local
**/.env.*.local
*.env